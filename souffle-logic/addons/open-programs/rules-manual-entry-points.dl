#include "../../commonMacros.dl"

// ===========================================================================
// manual-entry-points open-programs profile.
//
// Entry points are provided as facts (EntryPointMethod.facts -- hand-authored
// or generated, e.g. by an LLM) and read straight into EntryPointMethod by the
// central declaration (main/implicit-reachable-declarations.dl). All mock-object
// creation and wiring (receivers, arguments, fields, static fields, arrays) is
// done by the central mocking layer (souffle-logic/main/mocking/), which mocks
// every EntryPointMethod. This profile therefore only contributes the recall
// diagnostic below.
// ===========================================================================

// DeepReachableApplicationMethod (app methods reached via a real, non-mock call
// edge) is now defined once in addons/statistics/statistics-simple.dl.
