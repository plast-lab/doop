#include "../../commonMacros.dl"

// Receiver mock (`this`) for entry-point methods is created in the main analysis
// (souffle-logic/main/implicit-reachable.dl, "Mock receivers for entry points"):
// EntryPointMethod + Method_DeclaringType via TypeToConcreteImplementation.
// Set flag to enable statistics print logic.
#define OPEN_PROGRAM_MOCK_OBJS

// ---- feature components ----
