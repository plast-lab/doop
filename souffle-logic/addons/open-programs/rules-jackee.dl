#include "jackee-components/profile.dl"
#include "jackee-components/bean-method-beans.dl"
#include "jackee-components/framework-beans.dl"
#include "jackee-components/xml-beans.dl"
#include "jackee-components/injection-fields.dl"
#include "jackee-components/di-resolver.dl"
#include "jackee-components/dead-store-suppression.dl"
#include "jackee-components/xml-property-injection.dl"
#include "jackee-components/component-scan.dl"
#include "jackee-components/property-placeholder.dl"
#include "jackee-components/per-instance-mocking.dl"
