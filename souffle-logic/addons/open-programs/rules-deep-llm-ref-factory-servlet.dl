PossibleOpenProgramEntryPoint(?class, cat(cat("<", ?class), ": void <init>()>")),
PossibleOpenProgramEntryPoint(?class, cat(cat("<", ?class), ": void init(jakarta.servlet.FilterConfig)>")),
PossibleOpenProgramEntryPoint(?class, cat(cat("<", ?class), ": void init(javax.servlet.FilterConfig)>")),
PossibleOpenProgramEntryPoint(?class, cat(cat("<", ?class), ": void destroy()>")),
PossibleOpenProgramEntryPoint(?class, cat(cat("<", ?class), ": void doFilter(jakarta.servlet.ServletRequest,jakarta.servlet.ServletResponse,jakarta.servlet.FilterChain)>")),
PossibleOpenProgramEntryPoint(?class, cat(cat("<", ?class), ": void doFilter(javax.servlet.ServletRequest,javax.servlet.ServletResponse,javax.servlet.FilterChain)>")) :-
